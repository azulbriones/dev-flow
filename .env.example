# Frontend (Vite loads these at build time)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/api/v1

# Backend (FastAPI loads these at runtime)
DATABASE_URL=sqlite:///./devflow.db
REDIS_URL=redis://redis:6379/0
# NOTE: CORS is hardcoded in backend/app/main.py for WebSocket compatibility
# Use allow_origins=["*"] without credentials for WebSocket to work
CORS_ORIGINS=*

# CLI
DEVFLOW_API_URL=http://localhost:8000
